// This tells prisma how to connect to our database 
generator client {
  provider =  "prisma-client-js"
}

// we are using SQLite for local development (will be PostgreSQL in prod)
datasource db {
  provider = "sqlite"
}

// our Database Tables -

// This table will save every analysis your AI generates!
model analysis{
  id             String   @id @default(uuid()) // A unique random ID for every scan
  jobDescription String   // We save the JD they pasted
  gapScore       Int      // The overall match score (0-100)
  missingSkills  String   // The extracted skills list
  summary        String   // The AI's reasoning
  roadmap30      String   // Month 1 plan
  roadmap60      String   // Month 2 plan
  roadmap90      String   // Month 3 plan
  createdAt      DateTime @default(now()) // Automatically saves the exact date and time 
}